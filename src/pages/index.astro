  </div>
</section>

<!-- ===== TICKER ===== -->
<section class="ticker" aria-hidden="true">
  <div class="ticker-track">
    <span>Interiorismo técnico · Reforma · Cambio de uso · Asesoría · Render · Yécora · Logroño · Haro · Álava · Rioja · </span>
    <span>Interiorismo técnico · Reforma · Cambio de uso · Asesoría · Render · Yécora · Logroño · Haro · Álava · Rioja · </span>
  </div>
</section>

<!-- ===== MANIFIESTO ===== -->
<section class="manifest" id="manifiesto">
  <div class="manifest-grid">
    <aside class="manifest-meta">
      <p class="m-label">— Sobre el estudio</p>
      <p class="m-folio">Nº 01 · Manifiesto</p>
    </aside>
    <article class="manifest-body">
      <p class="manifest-q reveal">
        «No hacemos renders sin obra ni obras sin planos.
        Medimos la luz que entra, lo que cabe en la normativa,
        lo que aguanta el presupuesto. <em>El resto es vender humo.</em>»
      </p>
      <p class="manifest-sig">— María Iturbe Sánchez, ESDIR ’20 · nota 8,41</p>
    </article>
  </div>
</section>

<!-- ===== PROYECTOS ===== -->
<section class="works" id="proyectos">
  <header class="works-head">
    <div>
      <p class="kicker">02 · Trabajo seleccionado</p>
      <h2 class="display-2">
        <span>Pro</span><em>yec</em><span>tos</span>
      </h2>
    </div>
    <a href="/proyectos" class="all-link">Ver los 7 proyectos ↗</a>
  </header>

  {featured.map((p, i) => (
    <a href={`/proyectos/${p.slug}`} class={`work ${i % 2 === 1 ? 'work-rev' : ''}`}>
      <figure class="work-fig">
        <picture>
          <source srcset={strip(p, "avif", 0)} type="image/avif" />
          <source srcset={strip(p, "webp", 0)} type="image/webp" />
          <img src={pick(p, 0)} alt={p.title} loading={i < 2 ? "eager" : "lazy"} />
