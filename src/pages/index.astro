---
import "../styles/editorial.css";
import { SITE, SERVICES } from "../data/site";
import { PROJECTS, getFeaturedProjects } from "../data/projects";

const site = SITE;
const featured = getFeaturedProjects().slice(0, 6);

// Mapa slug proyecto → carpeta física real
const FOLDER: Record<string,string> = {
  "merendero-lapuebla": "lapuebla",
  "txoko-kripan": "kripan",
  "apartamentos-labastida": "labastida",
};

// Helper: limpia ruta absoluta de la galería (vienen como /images/projects/x/00.jpg)
const pick = (p: typeof featured[number], idx: number = 0) => {
  const raw = p.gallery[idx] ?? "";
  return raw.startsWith("/") ? raw : `/images/projects/${FOLDER[p.slug] ?? p.slug}/${raw}`;
};
const strip = (p: typeof featured[number], ext: string, idx: number = 0) => {
  const raw = p.gallery[idx] ?? "";
  return raw.replace(/\.[a-z0-9]+$/i, `.${ext}`);
};
const heroImg = pick(lapueblaFor(featured));
function lapueblaFor(arr: typeof featured) {
  return arr.find(p => p.slug === "merendero-lapuebla")!;
}
const mariaImg = "/team/maria.jpg";
const services = SERVICES.slice(0, 6);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>mit interiorismo — Yécora, Álava · desde 2020</title>
<meta name="description" content="Estudio de interiorismo técnico en Yécora, Álava. Más de 15 años entre dibujo, obra y territorio." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter+Tight:wght@300;400;500;600&display=swap" rel="stylesheet" />
<meta property="og:title" content="mit interiorismo" />
<meta property="og:description" content="Interiorismo técnico en Yécora, Álava" />
<meta property="og:image" content={`https://www.mitinteriorismo.studio${mariaImg}`} />
</head>
<body>

<!-- progress -->
<div class="prog" id="prog"></div>

<!-- nav -->
<header class="nav" id="nav">
  <a href="/" class="nav-mark">
    <span class="nav-mark-i">mit</span>
    <span class="nav-mark-s">Interiorismo · Yécora</span>
  </a>
  <nav class="nav-links">
    <a href="#proyectos" class="nav-l"><span>01</span>Proyectos</a>
    <a href="#estudio" class="nav-l"><span>02</span>Estudio</a>
    <a href="#contacto" class="nav-l"><span>03</span>Contacto</a>
  </nav>
</header>

<main id="main">

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-grid">
    <div class="hero-left">
      <div class="hairline"></div>
      <p class="kicker">Estudio · Interiorismo técnico · fundado 2020</p>
      <h1 class="display">
        <span class="d-line"><span>Donde el&nbsp;</span></span>
        <span class="d-line"><span><em>diseño</em></span></span>
        <span class="d-line"><span>encuentra</span></span>
        <span class="d-line"><span>a la&nbsp;<em>obra</em>.</span></span>
      </h1>
      <p class="hero-lede">
        Yécora (Álava) sirve a La Rioja, el País Vasco y cualquier cliente
        que entienda que un proyecto empieza con un replanteo, no con un render.
      </p>
      <div class="hero-meta">
        <a href="#proyectos" class="btn-pri">Ver proyectos →</a>
        <a href="#contacto" class="btn-ghost">Empezar conversación</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-fr">
        {heroImg && (
          <picture>
            <source srcset={strip(lapueblaFor(featured), "avif")} type="image/avif" />
            <source srcset={strip(lapueblaFor(featured), "webp")} type="image/webp" />
            <img src={heroImg} alt="Merendero en Lapuebla — interiorismo técnico mit" loading="eager" fetchpriority="high" />
          </picture>
        )}
        <div class="hero-fr-cap">
          <span>01 / 06</span>
          <span>Merendero Lapuebla · 2020</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== MARQUEE ===== -->
<section class="ticker" aria-hidden="true">
  <div class="ticker-track">
    <span>Interiorismo técnico · Reforma · Cambio de uso · Asesoría · Render · Yécora · Logroño · Haro · Álava · Rioja · </span>
    <span>Interiorismo técnico · Reforma · Cambio de uso · Asesoría · Render · Yécora · Logroño · Haro · Álava · Rioja · </span>
  </div>
</section>

<!-- ===== MANIFIESTO ===== -->
<section class="manifest" id="estudio-scroll">
  <div class="manifest-grid">
    <aside class="manifest-meta">
      <p class="m-label">— Sobre el estudio</p>
      <p class="m-folio">Nº 01 · Manifiesto</p>
    </aside>
    <article class="manifest-body">
      <p class="manifest-q reveal">
        «No hacemos renders sin obra ni obras sin planos. Medimos la
        luz que entra, lo que cabe en la normativa, lo que aguanta
        el presupuesto. <em>El resto es vender humo.</em>»
      </p>
      <p class="manifest-sig">— María Iturbe Sánchez, ESDIR ’20 · nota 8,41</p>
    </article>
  </div>
</section>

<!-- ===== PROYECTOS ===== -->
<section class="works" id="proyectos">
  <header class="works-head">
    <div>
      <p class="kicker">02 · Trabajo seleccionado</p>
      <h2 class="display-2">
        <span>Pro</span><em>yec</em><span>tos</span>
      </h2>
    </div>
    <a href="/proyectos" class="all-link">Ver los 7 proyectos ↗</a>
  </header>

  {featured.map((p, i) => (
    <a href={`/proyectos/${p.slug}`} class={`work ${i % 2 === 1 ? 'work-rev' : ''}`}>
      <figure class="work-fig">
        <picture>
          <source srcset={strip(p, "avif", 0)} type="image/avif" />
          <source srcset={strip(p, "webp", 0)} type="image/webp" />
          <img src={pick(p, 0)} alt={p.title} loading={i < 2 ? "eager" : "lazy"} />
        </picture>
        <figcaption class="work-cap">
          <span>0{i+1} / 0{featured.length}</span>
          <span>{p.year} · {p.location || 'Yécora'}</span>
        </figcaption>
      </figure>
      <div class="work-info">
        <p class="work-cat">{p.type === 'residential' ? 'Residencial' : p.type === 'commercial' ? 'Comercial' : p.type === 'office' ? 'Oficina' : 'Espacio social'}</p>
        <h3 class="work-title">{p.title}</h3>
        <p class="work-desc">{p.subtitle || ''}</p>
        <span class="work-go">Ver proyecto →</span>
      </div>
    </a>
  ))}
</section>

<!-- ===== ESTUDIO ===== -->
<section class="estudio" id="estudio">
  <div class="est-grid">
    <figure class="est-fig">
      <picture>
        <source srcset="/team/maria.avif" type="image/avif" />
        <source srcset="/team/maria.webp" type="image/webp" />
        <img src="/team/maria.jpg" alt="María Iturbe Sánchez" loading="lazy" />
      </picture>
      <span class="est-fig-tag">María, 2024 · Yécora</span>
    </figure>
    <div class="est-body">
      <p class="kicker">03 · El estudio</p>
      <h2 class="display-2">
        <span>María</span> <em>Iturbe</em><br/>
        <span>Sánchez</span>
      </h2>
      <p class="est-lead">
        Interiorista colegiada. 12 años en obra, 5 desde que abrió este estudio
        en un pueblo de 250 habitantes al sur de Álava.
      </p>
      <p class="est-tx">
        Antes: Echazarreta Construcciones (Logroño), Blurarquitectura (Bilbao),
        COOK Cocina &amp; Baño. Hoy: dirección de proyectos residenciales,
        comerciales y de cambio de uso — con planos, normativa y obra alineados.
      </p>
      <ul class="est-tools">
        <li>AutoCAD</li><li>SketchUp · V-Ray 5</li><li>Presto</li>
        <li>Photoshop</li><li>InDesign</li><li>CTE · REBT · RITE</li>
      </ul>
      <a href="/sobre" class="btn-pri">Trayectoria completa →</a>
    </div>
  </div>
</section>

<!-- ===== NÚMEROS ===== -->
<section class="nums">
  <div class="nums-grid">
    <div class="num"><p class="num-v">15<sup>+</sup></p><p class="num-l">Años en obra</p></div>
    <div class="num"><p class="num-v">8<sup>,41</sup></p><p class="num-l">Nota final ESDIR</p></div>
    <div class="num"><p class="num-v">40<sup>+</sup></p><p class="num-l">Proyectos dirigidos</p></div>
    <div class="num"><p class="num-v">∞</p><p class="num-l">Cafés con clientes</p></div>
  </div>
</section>

<!-- ===== SERVICIOS ===== -->
<section class="srv">
  <header class="srv-head">
    <p class="kicker">04 · Ámbito</p>
    <h2 class="display-2"><span>Qué </span><em>hace</em><span> el estudio</span></h2>
  </header>
  <div class="srv-grid">
    {services.map((s, i) => (
      <article class="srv-c">
        <p class="srv-n">0{i+1}</p>
        <h3 class="srv-tt">{s.title}</h3>
        <p class="srv-d">{s.description}</p>
        <span class="srv-a">Saber más ↗</span>
      </article>
    ))}
  </div>
</section>

<!-- ===== CONTACTO ===== -->
<section class="cta" id="contacto">
  <div class="cta-inner">
    <p class="kicker kicker-on-dark">05 · Contacto</p>
    <h2 class="display-2 cta-h">
      <span>¿Empezamos</span><br/>
      <em>cuando</em> <span>tú digas?</span>
    </h2>
    <p class="cta-lede">
      Una idea a medio gas ya es un proyecto. Escríbeme y quedamos
      en Yécora, Logroño o donde te pille mejor. Sin compromiso.
    </p>
    <div class="cta-actions">
      <a href="mailto:maria.iturbe.sanchez@gmail.com" class="btn-pri">Escribir a María</a>
      <a href="https://www.linkedin.com/in/mar%C3%ADaiturbe/" target="_blank" rel="noopener" class="btn-ghost on-dark">LinkedIn ↗</a>
    </div>
    <dl class="cta-info">
      <div><dt>Estudio</dt><dd>Yécora, Álava · CP 01322</dd></div>
      <div><dt>Email</dt><dd>maria.iturbe.sanchez@gmail.com</dd></div>
      <div><dt>Ámbito</dt><dd>Álava · La Rioja · País Vasco</dd></div>
    </dl>
  </div>
</section>

<!-- ===== FOOTER ===== -->
<footer class="foot">
  <p class="foot-m">
    mit <em>interiorismo</em> — {year} · Yécora, Álava
  </p>
  <p class="foot-s">Diseñado en territorio. Construido con planos, normativa y obra.</p>
</footer>

</main>

<script is:inline>
// === body ready (fire hero title reveal)
(function(){
  function go(){ document.body.classList.add('is-loaded'); }
  if (document.readyState === 'complete') go();
  else { window.addEventListener('load', go, {once:true}); }
  // fallback safety
  setTimeout(go, 500);
})();

// === progress bar
(function(){
  var p = document.getElementById('prog');
  function upd(){
    var h = document.documentElement.scrollHeight - window.innerHeight;
    if (h > 0 && p) p.style.width = (window.scrollY / h * 100) + '%';
  }
  window.addEventListener('scroll', upd, {passive:true});
  upd();
})();

// === nav state on scroll
(function(){
  var n = document.getElementById('nav');
  if (!n) return;
  function upd(){ if (window.scrollY > 60) n.classList.add('is-scrolled'); else n.classList.remove('is-scrolled'); }
  window.addEventListener('scroll', upd, {passive:true});
  upd();
})();

// === reveal on scroll
(function(){
  if (!('IntersectionObserver' in window)) {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('in'));
    return;
  }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, {threshold: 0.12, rootMargin: '0px 0px -60px 0px'});
  document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
})();

// === works: in-view flag + title split (unified)
(function(){
  function splitTitle(h){
    if (!h || h.dataset.split) return;
    h.dataset.split = '1';
    var t = h.textContent || '';
    h.innerHTML = t.split(' ').map(function(w, i){
      return '<span class="wt-w" style="transition-delay:'+(i*50)+'ms"><span class="wt-i">'+w+'</span></span>';
    }).join(' ');
  }
  function activate(el){
    el.classList.add('in');
    var t = el.querySelector('.work-title');
    splitTitle(t);
  }
  if (!('IntersectionObserver' in window)) {
    document.querySelectorAll('.work').forEach(activate);
    return;
  }
  // safety
  setTimeout(function(){ document.querySelectorAll('.work:not(.in)').forEach(activate); }, 5000);
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { activate(e.target); io.unobserve(e.target); }
    });
  }, {threshold: 0.05, rootMargin: '0px 0px -50px 0px'});
  document.querySelectorAll('.work').forEach(function(el){ io.observe(el); });
})();
</script>

</body>
</html>
