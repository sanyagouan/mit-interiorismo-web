      <line x1="200" y1="60" x2="200" y2="240"/>
      <line x1="80" y1="180" x2="320" y2="180"/>
      <!-- arcos de puertas -->
      <path d="M 200 180 A 20 20 0 0 1 240 180"/>
      <path d="M 200 240 A 20 20 0 0 0 200 200"/>
      <!-- ventanas -->
      <line x1="60" y1="80" x2="60" y2="160"/>
      <line x1="60" y1="180" x2="60" y2="260"/>
      <line x1="540" y1="80" x2="540" y2="180"/>
      <line x1="540" y1="240" x2="540" y2="320"/>
      <!-- cotas -->
      <line x1="80" y1="360" x2="320" y2="360"/>
      <line x1="78" y1="356" x2="78" y2="364"/>
      <line x1="318" y1="356" x2="318" y2="364"/>
      <text x="190" y="378" text-anchor="middle">5.40 m</text>
      <line x1="60" y1="60" x2="60" y2="340"/>
      <line x1="56" y1="58" x2="64" y2="58"/>
      <line x1="56" y1="340" x2="64" y2="340"/>
      <text x="44" y="200" text-anchor="middle" transform="rotate(-90 44 200)">4.20 m</text>
      <!-- texto identificativo -->
      <text x="80" y="48">MIT · PROYECTO TÉCNICO · ESC 1:50</text>
      <text x="540" y="48" text-anchor="end">PLANO 01 · ESTADO PREVIO</text>
    </svg>
