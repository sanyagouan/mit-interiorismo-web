        <figcaption class="work-cap">
          <span>0{i+1} / 0{featured.length}</span>
          <span>{p.year} · {p.location || 'Yécora'}</span>
        </figcaption>
      </figure>
      <div class="work-info">
        <p class="work-cat">{p.type === 'residential' ? 'Residencial' : p.type === 'commercial' ? 'Comercial' : p.type === 'office' ? 'Oficina' : 'Espacio social'}</p>
        <h3 class="work-title">{p.title}</h3>
        <p class="work-desc">{p.subtitle || ''}</p>
        <span class="work-go">Ver proyecto →</span>
      </div>
    </a>
  ))}
</section>

<!-- ===== ESTUDIO ===== -->
<section class="estudio" id="estudio">
  <div class="est-grid">
    <figure class="est-fig">
      <picture>
        <source srcset="/team/maria.avif" type="image/avif" />
        <source srcset="/team/maria.webp" type="image/webp" />
        <img src="/team/maria.jpg" alt="María Iturbe Sánchez" loading="lazy" />
      </picture>
      <span class="est-fig-tag">María, 2024 · Yécora</span>
    </figure>
    <div class="est-body">
      <p class="kicker">03 · El estudio</p>
      <h2 class="display-2">
        <span>María</span> <em>Iturbe</em><br/>
        <span>Sánchez</span>
      </h2>
      <p class="est-lead">
        «Interiorista colegiada. 12 años en obra, 5 desde que abrió este estudio
        en un pueblo de 250 habitantes al sur de Álava.»
      </p>
      <p class="est-tx">
        Antes: Echazarreta Construcciones (Logroño), Blurarquitectura (Bilbao),
        COOK Cocina &amp; Baño. Hoy: dirección de proyectos residenciales,
        comerciales y de cambio de uso — con planos, normativa y obra alineados.
      </p>
      <ul class="est-tools">
        <li>AutoCAD</li><li>SketchUp · V-Ray 5</li><li>Presto</li>
        <li>Photoshop</li><li>InDesign</li><li>CTE · REBT · RITE</li>
      </ul>
      <a href="/sobre" class="btn-pri">Trayectoria completa →</a>
    </div>
  </div>
</section>

<!-- ===== SERVICIOS ===== -->
<section class="srv" id="servicios">
  <header class="srv-head">
    <div>
      <p class="kicker">04 · Ámbito</p>
      <h2 class="display-2"><span>Qué </span><em>hace</em><span> el estudio</span></h2>
    </div>
    <p class="srv-intro-tx">
      Seis servicios vertebrados sobre una idea: ningún proyecto se entrega sin
      la ingeniería resuelta. Si quieres saber qué incluye cada uno, entra al detalle.
    </p>
  </header>
  <div class="srv-grid">
    {servicios.map((s, i) => (
      <a href={`/servicios/${s.id}`} class="srv-c" data-hover>
        <p class="srv-n">— 0{i+1}</p>
        <h3 class="srv-tt">{s.title}</h3>
        <p class="srv-d">{s.description}</p>
        <span class="srv-a">Saber más ↗</span>
      </a>
    ))}
  </div>
</section>

<!-- ===== CONTACTO ===== -->
<section class="cta" id="contacto">
  <div class="cta-inner">
    <p class="kicker kicker-on-dark">05 · Contacto</p>
    <h2 class="display-2 cta-h">
      <span>¿Empezamos</span><br/>
      <em>cuando</em> <span>tú digas?</span>
    </h2>
    <p class="cta-lede">
      Una idea a medio gas ya es un proyecto. Escríbeme o llámame, y quedamos
      en Yécora, Logroño o donde te pille mejor. Sin compromiso.
    </p>
    <div class="cta-actions">
      <a href={`mailto:${site.email}`} class="btn-pri">Escribir · {site.email}</a>
      <a href={`tel:${SITE.phoneRaw}`} class="btn-ghost on-dark">Llamar · {telefono}</a>
      <a href="https://wa.me/34637869890" target="_blank" rel="noopener" class="btn-ghost on-dark">WhatsApp ↗</a>
    </div>
    <dl class="cta-info">
      <div><dt>Estudio</dt><dd>{SITE.address.street}, {SITE.address.postalCode} {SITE.address.city}</dd></div>
      <div><dt>Email</dt><dd>{site.email}</dd></div>
      <div><dt>Teléfono</dt><dd>{telefono}</dd></div>
      <div><dt>Ámbito</dt><dd>Álava · La Rioja · País Vasco</dd></div>
      <div><dt>LinkedIn</dt><dd><a href={SITE.social.linkedin} target="_blank" rel="noopener">María Iturbe Sánchez ↗</a></dd></div>
      {SITE.social.instagram && (
        <div><dt>Instagram</dt><dd><a href={`https://www.instagram.com/${SITE.social.instagram.replace('@','')}/`} target="_blank" rel="noopener">@{SITE.social.instagram.replace('@','')} ↗</a></dd></div>
      )}
    </dl>
  </div>
</section>

<footer class="foot">
  <div class="foot-inner">
    <div class="foot-brand">
      <p class="foot-m">mit <em>interiorismo</em> — {year} · Yécora, Álava</p>
      <p class="foot-s">Diseñado en territorio. Construido con planos, normativa y obra.</p>
    </div>
    <ul class="foot-links">
      <li><a href="/proyectos">Proyectos</a></li>
      <li><a href="/sobre">Estudio</a></li>
      <li><a href="/servicios/reforma-integral">Servicios</a></li>
      <li><a href="/contacto">Contacto</a></li>
    </ul>
    <ul class="foot-links foot-legal">
      <li><a href="/aviso-legal">Aviso legal</a></li>
      <li><a href="/privacidad">Privacidad</a></li>
      <li><a href="/cookies">Cookies</a></li>
    </ul>
  </div>
</footer>

</main>

<script is:inline>
// body ready
(function(){
  function go(){ document.body.classList.add('is-loaded'); }
  if (document.readyState === 'complete') go();
  else { window.addEventListener('load', go, {once:true}); }
  setTimeout(go, 500);
})();

// progress bar
(function(){
  var p = document.getElementById('prog');
  function upd(){
    var h = document.documentElement.scrollHeight - window.innerHeight;
    if (h > 0 && p) p.style.width = (window.scrollY / h * 100) + '%';
  }
  window.addEventListener('scroll', upd, {passive:true});
  upd();
})();

// nav + toc state
(function(){
  var nav = document.getElementById('nav');
  var toc = document.getElementById('toc');
  function upd(){
    if (window.scrollY > 60) {
      if (nav) nav.classList.add('is-scrolled');
      if (toc) toc.classList.add('is-visible');
    } else {
      if (nav) nav.classList.remove('is-scrolled');
      if (toc) toc.classList.remove('is-visible');
    }
  }
  window.addEventListener('scroll', upd, {passive:true});
  upd();
})();

// reveal + works activation
(function(){
  function splitTitle(h){
    if (!h || h.dataset.split) return;
    h.dataset.split = '1';
    var t = h.textContent || '';
    h.innerHTML = t.split(' ').map(function(w, i){
      return '<span class="wt-w" style="transition-delay:'+(i*50)+'ms"><span class="wt-i">'+w+'</span></span>';
    }).join(' ');
  }
  function activate(el){
    el.classList.add('in');
    splitTitle(el.querySelector('.work-title'));
  }
  if (!('IntersectionObserver' in window)) {
    document.querySelectorAll('.work,.reveal').forEach(activate);
    return;
  }
  setTimeout(function(){ document.querySelectorAll('.work:not(.in),.reveal:not(.in)').forEach(activate); }, 5000);
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { activate(e.target); io.unobserve(e.target); }
    });
  }, {threshold: 0.05, rootMargin: '0px 0px -50px 0px'});
  document.querySelectorAll('.work,.reveal').forEach(function(el){ io.observe(el); });
})();

// hero slider
(function(){
  var slides = document.querySelectorAll('.hero-v2-render .slide');
  var thumbs = document.querySelectorAll('.hero-v2-thumb');
  if (slides.length < 2) return;
  var idx = 0;
  var timer = null;
  function show(n){
    idx = (n + slides.length) % slides.length;
    slides.forEach(function(s, i){
      s.classList.toggle('is-active', i === idx);
    });
    thumbs.forEach(function(t, i){
      t.classList.toggle('is-active', i === idx);
    });
  }
  function loop(){
    timer = setTimeout(function(){
      show(idx + 1);
      loop();
    }, 5500);
  }
  // pause on hover of right side
  var render = document.getElementById('hero-render');
  if (render) {
    render.addEventListener('mouseenter', function(){ if (timer) { clearTimeout(timer); timer = null; } });
    render.addEventListener('mouseleave', function(){ loop(); });
  }
  thumbs.forEach(function(t){
    t.addEventListener('click', function(){
      show(parseInt(t.dataset.slide, 10));
      if (timer) { clearTimeout(timer); timer = null; }
      loop();
    });
  });
  loop();
})();
</script>

</body>
</html>
