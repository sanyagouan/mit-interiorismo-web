  <div class="hero-v2-side hero-v2-render" id="hero-render">
    <div class="slide is-active" data-slide="0">
      <picture>
        <source srcset="/images/projects/kripan/03.avif" type="image/avif" />
        <source srcset="/images/projects/kripan/03.webp" type="image/webp" />
        <img src="/images/projects/kripan/03.jpg" alt="Txoko en Kripan · 2020" loading="eager" fetchpriority="high" />
      </picture>
    </div>
    <div class="slide" data-slide="1">
      <picture>
        <source srcset="/images/projects/kripan/11.avif" type="image/avif" />
        <source srcset="/images/projects/kripan/11.webp" type="image/webp" />
        <img src="/images/projects/kripan/11.jpg" alt="Txoko en Kripan · 2020" loading="eager" />
