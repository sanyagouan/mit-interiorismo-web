---
import "../styles/editorial.css";
import "../styles/hero-transformation.css";
import { SITE } from "../data/site";
import { PROJECTS, getFeaturedProjects } from "../data/projects";
import { SERVICIOS } from "../data/servicios";

const site = SITE;
const featured = getFeaturedProjects().slice(0, 6);

const FOLDER: Record<string,string> = {
  "merendero-lapuebla": "lapuebla",
  "txoko-kripan": "kripan",
  "apartamentos-labastida": "labastida",
};

const pick = (p: typeof featured[number], idx: number = 0) => {
  const raw = p.gallery[idx] ?? "";
  return raw.startsWith("/") ? raw : `/images/projects/${FOLDER[p.slug] ?? p.slug}/${raw}`;
};
const strip = (p: typeof featured[number], ext: string, idx: number = 0) => {
  const raw = p.gallery[idx] ?? "";
  return raw.replace(/\.[a-z0-9]+$/i, `.${ext}`);
};
const lapueblaFor = (arr: typeof featured) => arr.find(p => p.slug === "merendero-lapuebla")!;
const mariaImg = "/team/maria.jpg";
const servicios = SERVICIOS;
const year = new Date().getFullYear();
const telefono = SITE.phoneDisplay;
---

<!doctype html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>mit interiorismo — Donde el diseño encuentra a la obra · Yécora, Álava</title>
<meta name="description" content="Estudio de interiorismo técnico en Yécora, Álava. Más de 17 años entre dibujo, obra y territorio." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter+Tight:wght@300;400;500;600&display=swap" rel="stylesheet" />
<meta property="og:title" content="mit interiorismo" />
<meta property="og:description" content="Donde el diseño encuentra a la obra" />
<meta property="og:image" content={`https://www.mitinteriorismo.studio${mariaImg}`} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "mit interiorismo",
  "legalName": SITE.legalName,
  "description": site.tagline || site.shortDescription,
  "image": "https://www.mitinteriorismo.studio" + mariaImg,
  "url": "https://www.mitinteriorismo.studio",
  "telephone": SITE.phone,
  "email": SITE.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": SITE.address.street,
    "postalCode": SITE.address.postalCode,
    "addressLocality": SITE.address.city,
    "addressRegion": SITE.address.region,
    "addressCountry": SITE.address.country
  },
  "areaServed": ["Yécora", "Álava", "La Rioja", "Logroño", "Haro", "Vitoria", "País Vasco"],
  "priceRange": "€€"
})} />
</head>
<body>

<div class="prog" id="prog"></div>

<!-- nav principal -->
<header class="nav" id="nav">
  <a href="/" class="nav-mark">
    <span class="nav-mark-i">mit</span>
    <span class="nav-mark-s">Interiorismo · Yécora</span>
  </a>
  <nav class="nav-links">
    <a href="#proyectos" class="nav-l"><span>01</span>Proyectos</a>
    <a href="#estudio" class="nav-l"><span>02</span>Estudio</a>
    <a href="#servicios" class="nav-l"><span>03</span>Servicios</a>
    <a href="#contacto" class="nav-l"><span>04</span>Contacto</a>
  </nav>
</header>

<!-- Índice lateral flotante (aparece tras scroll) -->
<aside class="toc" id="toc" aria-hidden="true">
  <p class="toc-label">Índice</p>
  <ol>
    <li><a href="#" class="toc-l" data-target="top">00 · Inicio</a></li>
    <li><a href="#proyectos" class="toc-l" data-target="proyectos">01 · Proyectos</a></li>
    <li><a href="#estudio" class="toc-l" data-target="estudio">02 · Estudio</a></li>
    <li><a href="#servicios" class="toc-l" data-target="servicios">03 · Servicios</a></li>
    <li><a href="#contacto" class="toc-l" data-target="contacto">04 · Contacto</a></li>
  </ol>
</aside>

<main id="main">

<!-- ===== HERO CINEMATOGRÁFICO ===== -->
