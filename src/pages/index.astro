<script is:inline>
(function(){
  // HERO · TRANSFORMACIÓN
  // · 4 imágenes apiladas
  // · crossfade autoplay (6.5s por paso)
  // · controlable por scroll (rueda) y por click en steps
  // · pausa si el hero no está visible
  const stage = document.getElementById('hero-morph-stage');
  const hero  = document.getElementById('top');
  if (!stage || !hero) return;

  const layers = stage.querySelectorAll('.hero-morph-layer');
  const steps  = document.querySelectorAll('#hero-morph-foot .mf-step');
  const N = layers.length;
  let current = 0;       // 0..N-1
  let autoplay = null;
  let paused   = false;
  const DELAY = 8000;

  function go(i){
    i = (i + N) % N;
    if (i === current) return;
    layers[current].classList.remove('is-on');
    layers[i].classList.add('is-on');
    steps.forEach((s, k) => s.classList.toggle('is-active', k === i));
    current = i;
  }

  function next(){ go(current + 1); }
  function prev(){ go(current - 1); }

  function start(){
    stop();
    if (paused) return;
    autoplay = setInterval(next, DELAY);
  }
  function stop(){
    if (autoplay){ clearInterval(autoplay); autoplay = null; }
  }

  // === HERO scroll ===
  // El usuario hace scroll normal de página. La rueda/touch trackpad
  // en el hero transforma el proyecto. No bloqueamos el scroll vertical
  // (eso es UX terrible). En su lugar: en cuanto el hero deja de estar
  // visible al hacer scroll, la transformación se ha completado.
  // Para control fino: las teclas ←/→ y los botones del stepper.

  // En este modelo la "transformación" se desarrolla con autoplay + tiempo
  // que el usuario pasa en el hero. Si scroll-y > 0 dentro del hero,
  // aceleramos. Si scroll-y > 100px (saliendo), saltamos al final.

  function onScroll(){
    const r = hero.getBoundingClientRect();
    // cuánto ha scrolleado el usuario dentro del hero (en px)
    const scrolled = Math.max(0, -r.top);
    if (scrolled > 0 && scrolled < 40) {
      // acaba de empezar a salir → fuerza la última capa
      if (current !== N - 1) go(N - 1);
    }
    // si vuelve al hero, vuelve a la primera
    if (r.top > 50 && current !== 0) {
      go(0);
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  // Pausa con teclado (control fino)
  document.addEventListener('keydown', e => {
    const r = hero.getBoundingClientRect();
    if (r.bottom < 0 || r.top > innerHeight) return;
    if (e.key === 'ArrowRight') { next(); start(); e.preventDefault(); }
    if (e.key === 'ArrowLeft')  { prev(); start(); e.preventDefault(); }
  });

  // Click en step — el click PAUSA el autoplay
  steps.forEach((s, k) => s.addEventListener('click', () => {
    go(k);
    stop(); // pausa hasta que el usuario vuelva a interactuar
  }));

  start();
})();
</script>

