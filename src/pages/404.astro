---
/**
 * 404.astro
 * Página de error 404 con tono coherente al estudio.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Página no encontrada — MIT Interiorismo"
  description="La página que buscas no existe o se ha movido."
  noIndex
>
  <main id="main-content" class="grid min-h-[80vh] place-items-center bg-cream px-gutter">
    <div class="text-center">
      <p class="font-display text-display-xl text-teal-light">404</p>
      <h1 class="mt-4 font-display text-display-md text-ink">
        Esta página se ha mudado.
      </h1>
      <p class="mt-6 max-w-md text-ink-muted">
        Como los espacios que reformamos, a veces cambiamos las cosas de sitio.
        Te ayudamos a volver al inicio.
      </p>
      <a
        href="/"
        class="mt-10 inline-flex items-center gap-2 bg-teal px-8 py-4 text-sm font-medium text-cream transition-all duration-300 hover:bg-teal-deep"
      >
        Volver al inicio →
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>