---
/**
 * /contacto — Página de contacto
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title={`Contacto — ${SITE.name}`}
  description={`Ponte en contacto con ${SITE.name}. Hablemos sobre tu proyecto de interiorismo en ${SITE.address.city} (${SITE.address.region}) o cualquier punto de La Rioja y País Vasco.`}
>
  <main id="main-content" class="bg-cream">
    <section class="bg-cream py-section">
      <div class="mx-auto max-w-wide px-gutter">
        <div class="grid gap-12 md:grid-cols-12">
          <div class="md:col-span-5">
            <p class="mb-3 text-xs uppercase tracking-[0.25em] text-teal">
              Contacto
            </p>
            <h1 class="font-display text-display-xl text-ink">
              Hablemos.
            </h1>
            <p class="mt-6 text-lg text-ink-muted">
              Cuéntanos qué tienes en mente. Te respondemos en menos de 48h
              con una primera valoración y los siguientes pasos.
            </p>

            <div class="mt-12 space-y-6">
              <div>
                <p
                  class="mb-1 text-xs uppercase tracking-[0.2em] text-ink-light"
                >
                  Email
                </p>
                <a
                  href={`mailto:${SITE.email}`}
                  class="font-display text-xl text-ink transition-colors hover:text-teal"
                >
                  {SITE.email}
                </a>
              </div>
              <div>
                <p
                  class="mb-1 text-xs uppercase tracking-[0.2em] text-ink-light"
                >
                  Ubicación del estudio
                </p>
                <p class="font-display text-xl text-ink">
                  {SITE.address.city}, {SITE.address.region}
                </p>
              </div>
              <div>
                <p
                  class="mb-1 text-xs uppercase tracking-[0.2em] text-ink-light"
                >
                  Zona de actuación
                </p>
                <p class="text-ink">
                  La Rioja (Logroño, Haro) · Álava (Yécora) · País Vasco
                </p>
              </div>
            </div>
          </div>

          <div class="md:col-span-7">
            <ContactForm />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>