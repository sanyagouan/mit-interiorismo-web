---
/**
 * /servicios/[id] — Detalle de cada servicio
 * Generated from src/data/servicios.ts
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SERVICIOS } from '../../data/servicios';

export async function getStaticPaths() {
  return SERVICIOS.map(s => ({ params: { id: s.id }, props: { servicio: s } }));
}

const { servicio } = Astro.props as { servicio: typeof SERVICIOS[number] };
const idx = SERVICIOS.findIndex(s => s.id === servicio.id);
const prev = SERVICIOS[(idx - 1 + SERVICIOS.length) % SERVICIOS.length];
const next = SERVICIOS[(idx + 1) % SERVICIOS.length];

const num = String(idx + 1).padStart(2, '0');
---
<BaseLayout
  title={`${servicio.title} — ${Astro.locals.SITE?.name ?? 'mit interiorismo'}`}
  description={servicio.description.slice(0, 160)}
>
  <main class="srv-page">
    <a href="/#servicios" class="srv-back">← Volver a servicios</a>

    <header class="srv-head">
      <p class="kicker">{num} / {String(SERVICIOS.length).padStart(2,'0')} · Servicio</p>
      <h1>{servicio.title}</h1>
      <p class="srv-subtitle">{servicio.subtitle}</p>
    </header>

    <section class="srv-intro">
      <p>{servicio.description}</p>
    </section>

    <section class="srv-includes">
      <h2>Qué incluye</h2>
      <ul>
        {servicio.includes.map(item => <li>{item}</li>)}
      </ul>
    </section>

    {servicio.duration && (
      <section class="srv-meta">
        <div>
          <p class="meta-l">Plazo orientativo</p>
          <p class="meta-v">{servicio.duration}</p>
        </div>
        {servicio.fromPrice && (
          <div>
            <p class="meta-l">Honorarios</p>
            <p class="meta-v">{servicio.fromPrice}</p>
          </div>
        )}
      </section>
    )}

    <section class="srv-cta">
      <p class="kicker">¿Te interesa?</p>
      <h2>Hablemos de tu proyecto</h2>
      <p class="srv-cta-tx">Una primera reunión es sin compromiso — en Yécora, Logroño, Haro o donde prefieras.</p>
      <div class="srv-cta-actions">
        <a href="/contacto" class="btn-pri">Pedir cita</a>
        <a href={`tel:+34637869890`} class="btn-ghost">Llámanos · 637 86 98 90</a>
      </div>
    </section>

    <nav class="srv-pager">
      <a href={`/servicios/${prev.id}`} class="pager-l">
        <span>← Anterior</span>
        <strong>{prev.title}</strong>
      </a>
      <a href={`/servicios/${next.id}`} class="pager-r">
        <span>Siguiente →</span>
        <strong>{next.title}</strong>
      </a>
    </nav>
  </main>
</BaseLayout>

<style>
  .srv-page{
    background:var(--paper);
    color:var(--ink);
    font-family:var(--sans);
    padding:160px 40px 100px;
    max-width:920px;
    margin:0 auto;
  }
  .srv-back{
    display:inline-block;
    font-size:12px;
    text-transform:uppercase;
    letter-spacing:0.18em;
    color:var(--g500);
    margin-bottom:60px;
    border-bottom:1px solid transparent;
    transition:color .25s, border-color .25s;
  }
  .srv-back:hover{ color:var(--wine); border-color:var(--wine); }

  .srv-head{ margin-bottom:60px; }
  .kicker{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.22em;
    color:var(--wine);
    font-weight:600;
    margin:0 0 18px;
  }
  h1{
    font-family:var(--serif);
    font-weight:300;
    font-size:clamp(48px,6vw,96px);
    line-height:1;
    letter-spacing:-0.03em;
    margin:0 0 24px;
  }
  .srv-subtitle{
    font-family:var(--serif);
    font-style:italic;
    font-weight:300;
    font-size:clamp(20px,1.8vw,28px);
    line-height:1.4;
    color:var(--g700);
    max-width:560px;
    margin:0;
  }

  .srv-intro{
    border-top:1px solid var(--g100);
    padding-top:40px;
    margin-bottom:60px;
  }
  .srv-intro p{
    font-family:var(--serif);
    font-weight:300;
    font-size:clamp(18px,1.6vw,24px);
    line-height:1.55;
    color:var(--ink);
    margin:0;
  }

  .srv-includes{ margin-bottom:60px; }
  .srv-includes h2{
    font-family:var(--serif);
    font-weight:400;
    font-size:28px;
    margin:0 0 24px;
    color:var(--ink);
  }
  .srv-includes ul{
    list-style:none;
    padding:0;
    margin:0;
    border-top:1px solid var(--g100);
  }
  .srv-includes li{
    border-bottom:1px solid var(--g100);
    padding:18px 0 18px 32px;
    font-size:15px;
    line-height:1.6;
    color:var(--g700);
    position:relative;
  }
  .srv-includes li::before{
    content:"";
    position:absolute;
    left:0; top:24px;
    width:18px;
    height:1px;
    background:var(--wine);
  }

  .srv-meta{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:40px;
    background:var(--bone);
    padding:40px;
    margin-bottom:60px;
  }
  .meta-l{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.2em;
    color:var(--g500);
    margin:0 0 8px;
    font-weight:600;
  }
  .meta-v{
    font-family:var(--serif);
    font-style:italic;
    font-size:22px;
    color:var(--ink);
    margin:0;
  }

  .srv-cta{
    background:var(--ink);
    color:var(--paper);
    padding:60px 40px;
    margin:60px -40px 0;
    text-align:center;
  }
  .srv-cta .kicker{ color:var(--gold); }
  .srv-cta h2{
    font-family:var(--serif);
    font-weight:300;
    font-size:clamp(36px,4.5vw,60px);
    line-height:1.05;
    letter-spacing:-0.025em;
    margin:0 0 20px;
    color:var(--paper);
  }
  .srv-cta-tx{
    font-family:var(--serif);
    font-style:italic;
    font-size:18px;
    color:var(--g300);
    margin:0 0 32px;
  }
  .srv-cta-actions{
    display:flex;
    gap:14px;
    justify-content:center;
    flex-wrap:wrap;
  }
  .btn-pri{
    background:var(--paper);
    color:var(--ink);
    padding:16px 26px;
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.18em;
    font-weight:600;
    transition:background .3s;
    border:1px solid var(--paper);
  }
  .btn-pri:hover{ background:var(--gold); border-color:var(--gold); }
  .btn-ghost{
    background:transparent;
    color:var(--paper);
    padding:16px 26px;
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.18em;
    font-weight:500;
    border:1px solid var(--paper);
    transition:background .3s, color .3s;
  }
  .btn-ghost:hover{ background:var(--paper); color:var(--ink); }

  .srv-pager{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:24px;
    margin-top:60px;
    border-top:1px solid var(--g100);
    padding-top:40px;
  }
  .pager-l, .pager-r{
    display:flex;
    flex-direction:column;
    gap:6px;
    color:var(--ink);
    transition:color .25s;
  }
  .pager-r{ text-align:right; }
  .pager-l span, .pager-r span{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:0.18em;
    color:var(--g500);
    font-weight:500;
  }
  .pager-l strong, .pager-r strong{
    font-family:var(--serif);
    font-style:italic;
    font-weight:400;
    font-size:18px;
  }
  .pager-l:hover, .pager-r:hover{ color:var(--wine); }

  @media (max-width:760px){
    .srv-page{ padding:120px 22px 60px; }
    .srv-meta{ grid-template-columns:1fr; gap:24px; padding:28px; }
    .srv-cta{ margin:40px -22px 0; padding:40px 22px; }
    .srv-pager{ grid-template-columns:1fr; gap:24px; }
    .pager-r{ text-align:left; }
  }
</style>
</content>
