---
/**
 * ContactForm.astro
 * Formulario de contacto con campos básicos.
 * Protección anti-spam honeypot + validación client-side.
 */
---

<form
  action="https://formspree.io/f/REEMPLAZAR_CON_FORM_ID"
  method="POST"
  class="space-y-6"
  data-contact-form
  novalidate
>
  <!-- Honeypot anti-spam — invisible para humanos -->
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <label for="name" class="mb-2 block text-sm font-medium text-ink"> Nombre </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full border-b border-ink/30 bg-transparent px-1 py-3 text-ink transition-colors focus:border-teal focus:outline-none"
      />
    </div>

    <div>
      <label for="email" class="mb-2 block text-sm font-medium text-ink">
        Email
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        class="w-full border-b border-ink/30 bg-transparent px-1 py-3 text-ink transition-colors focus:border-teal focus:outline-none"
      />
    </div>
  </div>

  <div>
    <label for="phone" class="mb-2 block text-sm font-medium text-ink">
      Teléfono <span class="text-ink-light">(opcional)</span>
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      autocomplete="tel"
      class="w-full border-b border-ink/30 bg-transparent px-1 py-3 text-ink transition-colors focus:border-teal focus:outline-none"
    />
  </div>

  <div>
    <label for="service" class="mb-2 block text-sm font-medium text-ink">
      ¿Qué necesitas?
    </label>
    <select
      id="service"
      name="service"
      class="w-full border-b border-ink/30 bg-transparent px-1 py-3 text-ink transition-colors focus:border-teal focus:outline-none"
    >
      <option value="">Selecciona una opción</option>
      <option value="reforma-integral">Reforma integral</option>
      <option value="decoracion">Decoración</option>
      <option value="consultoria">Consultoría de diseño</option>
      <option value="home-staging">Home staging</option>
      <option value="otro">Otro / no estoy seguro</option>
    </select>
  </div>

  <div>
    <label for="message" class="mb-2 block text-sm font-medium text-ink">
      Cuéntanos sobre tu proyecto
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full border-b border-ink/30 bg-transparent px-1 py-3 text-ink transition-colors focus:border-teal focus:outline-none"
    ></textarea>
  </div>

  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="privacy"
      name="privacy"
      required
      class="mt-1 h-4 w-4 accent-teal"
    />
    <label for="privacy" class="text-sm text-ink-muted">
      He leído y acepto la
      <a href="/privacidad" class="underline hover:text-teal">política de privacidad</a>.
    </label>
  </div>

  <button
    type="submit"
    class="group inline-flex items-center gap-2 bg-teal px-8 py-4 text-sm font-medium text-cream transition-all duration-300 hover:bg-teal-deep"
  >
    Enviar mensaje
    <span class="inline-block transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
  </button>
</form>